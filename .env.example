# SITE CONFIGURATION
# ------------------------------------------------------------------------------
# The primary URL of your application. Used for SEO, Sitemaps, and OG Images.
NEXT_PUBLIC_APP_URL=https://devtools-suite.app

# FIREBASE CONFIGURATION
# ------------------------------------------------------------------------------
# Used for Firebase Analytics and secondary services.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# SECURITY & VERIFICATION
# ------------------------------------------------------------------------------
# Cloudflare Turnstile Site Key for bot protection on the DNS Lookup tool.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# GENERATIVE AI (GENKIT)
# ------------------------------------------------------------------------------
# Google Gemini API Key for AI features like Regex Generation.
GOOGLE_GENAI_API_KEY=
